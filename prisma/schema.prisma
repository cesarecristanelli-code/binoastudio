// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatoImmobile {
  NUOVO
  BUONO
  RISTRUTTURATO
  DA_RISTRUTTURARE
}

enum ClasseEnergetica {
  A4
  A3
  A2
  A1
  B
  C
  D
  E
  F
  G
}

model User {
  id        String    @id @default(cuid())
  username  String    @unique
  email     String    @unique
  password  String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Immobile {
  id           String @id @default(cuid())
  slug         String @unique
  nome         String
  indirizzo    String
  citta        String
  metratura    Int
  numeroLocali Int
  numeroBagni  Int
  descrizione  String @db.Text
  prezzo       Float

  piano           String?
  pianiCondominio Int?
  ascensore       Boolean @default(false)
  giardino        Boolean @default(false)
  boxAuto         Int     @default(0)
  numeroTerrazzi  Int     @default(0)
  numeroBalconi   Int     @default(0)

  stato             StatoImmobile    @default(BUONO)
  classeEnergia     ClasseEnergetica @default(G)
  speseCondominiali Float?
  arredato          Boolean          @default(false)

  createdAt DateTime           @default(now())
  updatedAt DateTime           @default(now()) @updatedAt
  immagini  ImmagineImmobile[]
}

model ImmagineImmobile {
  id         String   @id @default(cuid())
  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)
  url        String   @unique
  isCover    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}
